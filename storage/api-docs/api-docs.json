                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "Task": {
                "properties": {
                    "id": {
                        "description": "Идентификатор задачи",
                        "type": "integer",
                        "example": 1
                    },
                    "user_id": {
                        "description": "Владелец задачи",
                        "type": "integer",
                        "example": 1
                    },
                    "title": {
                        "description": "Заголовок (3-255 символов)",
                        "type": "string",
                        "example": "Купить молоко"
                    },
                    "description": {
                        "description": "Описание",
                        "type": "string",
                        "example": "2 литра овсяного",
                        "nullable": true
                    },
                    "due_date": {
                        "description": "Дедлайн",
                        "type": "string",
                        "format": "date",
                        "example": "2026-08-01",
                        "nullable": true
                    },
                    "status": {
                        "description": "Статус: pending — ожидающая, in_progress — в работе, completed — завершена",
                        "type": "string",
                        "example": "pending",
                        "enum": [
                            "pending",
                            "in_progress",
                            "completed"
                        ]
                    },
                    "created_at": {
                        "description": "Дата создания",
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "description": "Дата обновления",
                        "type": "string",
                        "format": "date-time"
                    },
                    "can_update": {
                        "description": "Может ли текущий пользователь редактировать",
                        "type": "boolean",
                        "example": true
                    },
                    "can_delete": {
                        "description": "Может ли текущий пользователь удалить",
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "User": {
                "properties": {
                    "id": {
                        "description": "Идентификатор пользователя",
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "description": "Имя пользователя",
                        "type": "string",
                        "example": "Алиса"
                    },
                    "email": {
                        "description": "Email",
                        "type": "string",
                        "format": "email",
                        "example": "admin@example.com"
                    },
                    "is_admin": {
                        "description": "Является ли администратором",
                        "type": "boolean",
                        "example": true
                    },
                    "created_at": {
                        "description": "Дата создания",
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "description": "Дата обновления",
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "description": "Bearer-токен Laravel Sanctum. Возвращается из POST /api/auth/login.",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Авторизация",
            "description": "Авторизация"
        },
        {
            "name": "Задачи",
            "description": "Задачи"
        }
    ]
}